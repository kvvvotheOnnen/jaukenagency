---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto">
  <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden bg-[#050505] text-slate-100 font-display transition-colors duration-300 antialiased">
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#e63946]/10 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[40%] h-[40%] bg-[#e63946]/5 blur-[150px] rounded-full"></div>
      <div class="absolute top-[30%] right-[10%] w-[30%] h-[30%] bg-white/[0.02] blur-[100px] rounded-full"></div>
    </div>

    <Header />

    <main class="relative bg-background-dark overflow-hidden pt-20">
      <section class="px-6 py-16 lg:py-24 text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-7xl font-black tracking-tighter mb-6 text-white leading-tight">
          Conversemos sobre tu proyecto
        </h1>
        <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed">
          Transformamos ideas en experiencias digitales memorables con precisión técnica y diseño de vanguardia.
        </p>
      </section>

      <section class="px-6 pb-24">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24">
          <div class="space-y-12">
            <div>
              <h3 class="text-2xl font-bold mb-8 text-white">Información de Contacto</h3>
              <div class="space-y-6">
                <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:bg-white/[0.03] group">
                  <div class="flex items-center justify-center size-12 rounded-lg bg-white/5 text-white group-hover:bg-[#e63946]/20 group-hover:text-[#e63946] transition-colors">
                    <span class="material-symbols-outlined">mail</span>
                  </div>
                  <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Correo Electrónico</p>
                    <p class="text-lg font-medium text-white">hola@jauken.design</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:bg-white/[0.03] group">
                  <div class="flex items-center justify-center size-12 rounded-lg bg-white/5 text-white group-hover:bg-[#e63946]/20 group-hover:text-[#e63946] transition-colors">
                    <span class="material-symbols-outlined">location_on</span>
                  </div>
                  <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Ubicación</p>
                    <p class="text-lg font-medium text-white">Santiago, Chile</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="p-8 rounded-2xl bg-[#0a0a0a] border border-white/5 shadow-2xl relative overflow-hidden group">
              <div class="absolute top-0 right-0 w-32 h-32 bg-[#e63946]/10 blur-[60px] rounded-full -mr-16 -mt-16 group-hover:bg-[#e63946]/20 transition-colors"></div>
              <h4 class="text-xl font-bold mb-4 text-white relative z-10">¿Buscas una respuesta rápida?</h4>
              <p class="text-slate-400 mb-8 relative z-10 leading-relaxed">Chatea con nosotros directamente por WhatsApp para consultas urgentes o presupuestos rápidos.</p>
              <button class="w-full flex items-center justify-center gap-2 border border-white/10 hover:border-[#e63946]/40 bg-white/5 hover:bg-[#e63946]/5 text-white font-bold py-4 rounded-xl transition-all relative z-10">
                <span class="material-symbols-outlined text-[20px]">chat</span>
                Escríbenos por WhatsApp
              </button>
            </div>
          </div>

          <div class="bg-[#0a0a0a] p-8 md:p-12 rounded-2xl shadow-2xl border border-white/5">
            <form class="space-y-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-slate-500" for="name">Nombre completo</label>
                <input
                  class="w-full bg-black border border-white/10 rounded-lg px-4 py-4 text-white placeholder:text-slate-700 focus:ring-1 focus:ring-[#e63946]/50 focus:border-[#e63946]/50 outline-none transition-all"
                  id="name"
                  name="name"
                  placeholder="Tu nombre"
                  type="text"
                />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-slate-500" for="email">Correo Electrónico</label>
                <input
                  class="w-full bg-black border border-white/10 rounded-lg px-4 py-4 text-white placeholder:text-slate-700 focus:ring-1 focus:ring-[#e63946]/50 focus:border-[#e63946]/50 outline-none transition-all"
                  id="email"
                  name="email"
                  placeholder="tu@email.com"
                  type="email"
                />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-slate-500" for="message">Mensaje</label>
                <textarea
                  class="w-full bg-black border border-white/10 rounded-lg px-4 py-4 text-white placeholder:text-slate-700 focus:ring-1 focus:ring-[#e63946]/50 focus:border-[#e63946]/50 outline-none transition-all resize-none"
                  id="message"
                  name="message"
                  placeholder="Cuéntanos sobre tu idea..."
                  rows="5"
                ></textarea>
              </div>
              <button
                class="w-full bg-[#e63946] hover:bg-[#e63946]/90 text-white font-black py-5 rounded-lg uppercase tracking-[0.2em] text-sm transition-all transform active:scale-[0.98] shadow-2xl shadow-[#e63946]/20"
                type="submit"
              >
                Enviar Mensaje
              </button>
            </form>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>